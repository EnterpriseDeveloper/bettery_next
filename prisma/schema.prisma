generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model IndexerState {
  id        Int      @id @default(1)
  lastBlock BigInt
  updatedAt DateTime @updatedAt
}

model Event {
  id           BigInt        @id
  creator      String
  question     String
  answers      String[]
  answersPool  BigInt[]
  endTime      BigInt
  startTime    BigInt
  category     String
  status       String
  roomId       String
  createdAt    DateTime      @default(now())
  bets         Participant[]
  validators   Validator[]
}

model Participant {
  id        BigInt @id
  creator   String
  eventId   BigInt
  answer    String
  amount    BigInt
  token     String
  result    BigInt
  status    String
  createdAt BigInt
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([creator])
}

model Validator {
  id            BigInt  @id
  creator       String
  eventId       BigInt
  answer        String
  source        String
  refunded      Boolean
  companyAmount BigInt
  createdAt     BigInt
  event         Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
